# Environment Variables
NODE_ENV=development

# Database Configuration
POSTGRES_HOST=192.168.1.127
POSTGRES_PORT=5432
POSTGRES_DB=shortlink
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Configuration  
REDIS_HOST=192.168.1.127
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB Configuration
MONGODB_URI=mongodb://192.168.1.127:27017
MONGODB_DATABASE=shortlink_analytics

# Kafka Configuration
KAFKA_BROKERS=192.168.1.127:9092
KAFKA_TOPIC_CLICKS=shortlink_clicks

# JWT Configuration
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast256BitsLongForHMACSecurityRequirements
JWT_EXPIRES_IN=24h

# API Gateway
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0

# Service Ports
SHORTLINK_SERVICE_PORT=8081
REDIRECT_SERVICE_PORT=8082
ANALYTICS_SERVICE_PORT=8083
USER_MANAGEMENT_SERVICE_PORT=8084

# Service URLs (for internal communication)
SHORTLINK_SERVICE_URL=http://localhost:8081
REDIRECT_SERVICE_URL=http://localhost:8082
ANALYTICS_SERVICE_URL=http://localhost:8083
USER_MANAGEMENT_SERVICE_URL=http://localhost:8084

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=200

# Domain Configuration
BASE_DOMAIN=http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
PROMETHEUS_PORT=9090
METRICS_PATH=/metrics
